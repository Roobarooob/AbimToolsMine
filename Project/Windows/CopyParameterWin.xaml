<Window x:Class="AbimToolsMine.CopyParameterWin"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
Title="Копирование параметров"
        Width="550" Height="520" MinHeight="550"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="SingleBorderWindow"
        Background="WhiteSmoke"
        Topmost="True">

    <Grid Margin="10">
        <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

        <!-- Источник элементов -->
        <GroupBox Grid.Row="0" Header="Источник элементов" Margin="0,0,0,8">
  <Grid Margin="5">
     <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
 <RowDefinition Height="Auto"/>
           <RowDefinition Height="*"/>
     <RowDefinition Height="Auto"/>
   <RowDefinition Height="Auto"/>
             <RowDefinition Height="Auto"/>
   </Grid.RowDefinitions>

       <RadioButton Grid.Row="0" x:Name="RbAllCategories" Content="Все элементы категории"
             IsChecked="True" Checked="RbSource_Checked"/>

       <!-- Фильтр -->
     <TextBox Grid.Row="1" x:Name="TbCategoryFilter"
             Margin="16,4,0,2" Height="22" Background="White"
      VerticalContentAlignment="Center"
      IsEnabled="{Binding IsChecked, ElementName=RbAllCategories}"
             TextChanged="OnCategoryFilterChanged">
          <TextBox.Style>
      <Style TargetType="TextBox">
   <Setter Property="Background" Value="White"/>
   <Style.Resources>
        <VisualBrush x:Key="HintBrush" TileMode="None" Opacity="0.4"
  Stretch="None" AlignmentX="Left">
    <VisualBrush.Visual>
        <TextBlock Text="Поиск категории..." FontStyle="Italic" Margin="2,0,0,0"/>
</VisualBrush.Visual>
   </VisualBrush>
               </Style.Resources>
         <Style.Triggers>
          <MultiTrigger>
         <MultiTrigger.Conditions>
    <Condition Property="Text" Value=""/>
          <Condition Property="IsFocused" Value="False"/>
       </MultiTrigger.Conditions>
<Setter Property="Background" Value="{StaticResource HintBrush}"/>
      </MultiTrigger>
  </Style.Triggers>
          </Style>
     </TextBox.Style>
 </TextBox>

   <!-- Список с чекбоксами -->
    <ListBox Grid.Row="2" x:Name="LbCategories" Margin="16,2,0,2"
     IsEnabled="{Binding IsChecked, ElementName=RbAllCategories}"
 BorderThickness="1" SelectionMode="Multiple">
        <ListBox.ItemTemplate>
          <DataTemplate>
           <CheckBox Content="{Binding Name}"
           IsChecked="{Binding IsChecked, Mode=TwoWay}"
          Checked="OnCategoryCheckedChanged"
        Unchecked="OnCategoryCheckedChanged"/>
                  </DataTemplate>
              </ListBox.ItemTemplate>
                </ListBox>

       <!-- Выбранные категории -->
                <TextBlock Grid.Row="3" x:Name="TbSelectedSummary"
        Margin="16,2,0,0" FontStyle="Italic" Foreground="Gray" FontSize="11"
       TextWrapping="Wrap" Text="Выбрано: нет"
    IsEnabled="{Binding IsChecked, ElementName=RbAllCategories}"/>

        <RadioButton Grid.Row="4" x:Name="RbSelection" Content="Выбранные элементы"
    Margin="0,6,0,0" Checked="RbSource_Checked"/>
    <TextBlock Grid.Row="5" x:Name="TbSelectionCount"
        Margin="16,2,0,0" FontStyle="Italic" Foreground="Gray" FontSize="11"
              Text="Выбрано элементов: 0"/>
  </Grid>
        </GroupBox>

    <!-- Режим копирования -->
        <GroupBox Grid.Row="1" Header="Режим копирования" Margin="0,0,0,8">
     <StackPanel Margin="5">
            <RadioButton x:Name="RbModeWithin" Content="Копирование внутри элемента"
         IsChecked="True" Checked="OnModeChanged"/>
 <RadioButton x:Name="RbModeNested" Content="Копирование во вложенные элементы"
       Margin="0,4,0,0" Checked="OnModeChanged"/>
    </StackPanel>
        </GroupBox>

        <!-- Параметры -->
        <GroupBox Grid.Row="2" Margin="0,0,0,8">
   <Grid Margin="5">
      <Grid.ColumnDefinitions>
         <ColumnDefinition Width="Auto"/>
             <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
     <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
   </Grid.RowDefinitions>

  <Label Grid.Row="0" Grid.Column="0" x:Name="LblFromParam"
  Content="Из параметра:" VerticalAlignment="Center"/>
       <TextBox Grid.Row="0" Grid.Column="1" x:Name="TbFromParam"
       Margin="4,2" Height="24" VerticalContentAlignment="Center"/>

      <!-- Строка "В параметр" — скрывается в режиме вложенных -->
    <Label Grid.Row="1" Grid.Column="0" x:Name="LblToParam"
   Content="В параметр:" VerticalAlignment="Center"/>
      <TextBox Grid.Row="1" Grid.Column="1" x:Name="TbToParam"
   Margin="4,2" Height="24" VerticalContentAlignment="Center"/>
   </Grid>
        </GroupBox>

        <!-- Опции -->
        <CheckBox x:Name="CbOnlyEmpty" Grid.Row="3"
        Content="Копировать только в незаполненные параметры" Margin="0,0,0,10"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Content="Выполнить" Width="90" Height="26" Margin="0,0,8,0" Click="OnExecuteClick"/>
   <Button Content="Отмена"    Width="90" Height="26" Click="OnCancelClick"/>
     </StackPanel>
    </Grid>
</Window>
