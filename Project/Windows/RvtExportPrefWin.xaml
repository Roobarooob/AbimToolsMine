<Window x:Class="AbimToolsMine.RvtExportPrefWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="RVT Export Settings" Height="150" Width="350" Background="WhiteSmoke" Closing="Window_Closing">
<Grid Margin="10">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Content="Revit Server Name"/>
        <TextBox x:Name="ServerNameTextBox" Grid.Row="1" Margin="0,0,0,10" Height="30" 
      HorizontalContentAlignment="Center" VerticalContentAlignment="Center" 
      TextChanged="ServerNameTextBox_TextChanged"/>
    </Grid>
</Window>
